# Supabase (mismo proyecto que la app móvil)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# URL pública del sitio (redirects OAuth y reset password)
# Producción: https://fitforge.mobile
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile (opcional, mismo que la app móvil)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# App stores (cuando estén publicadas)
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=io.fitforge.fitforge
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id0000000000

# Stripe (fase suscripciones)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
